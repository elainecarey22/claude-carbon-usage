# Copy this file to .env and fill in your values
# Never commit .env to version control

# Electricity Maps API key — get a free key at
# https://www.electricitymaps.com/free-tier-api
ELECTRICITY_MAPS_API_KEY=

# Grid region to price energy against (Electricity Maps zone code).
# Default is IE (Ireland). Examples: GB, FR, DE, US-CAL-CISO, US-NY-NYIS.
# Full list: https://api.electricitymap.org/v3/zones
ELECTRICITY_MAPS_ZONE=IE
